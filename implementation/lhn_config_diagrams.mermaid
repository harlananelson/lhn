```mermaid
flowchart TB
    subgraph INIT["Resources.__init__()"]
        A1[/"project='SickleCell'<br/>spark=spark<br/>process_all=True"/]
        A2["Set basePath, config_file"]
        A3["Initialize config_table_locations:<br/>• config_local → 000-config.yaml<br/>• config_global → config-global.yaml"]
        A4["Initialize replace dict:<br/>• today → current date<br/>• dataPath → basePath"]
        A5{"process_all?"}
        A1 --> A2 --> A3 --> A4 --> A5
    end

    subgraph CONFIG["read_config_all()"]
        B1["Load 000-config.yaml"]
        B2["Apply ${var} substitution"]
        B3["Merge into config_dict"]
        B4["Load config-global.yaml"]
        B5["Discover config_table_locations"]
        B6["Load each referenced config<br/>(config-RWD.yaml, etc.)"]
        B7["Merge all into config_dict"]
        B1 --> B2 --> B3 --> B4 --> B5 --> B6 --> B7
    end

    subgraph PROCESS["processAllDataTables()"]
        C1["Get schemas dict from config_dict"]
        C2["Get callFunProcessDataTables dict"]
        C3["For each schema in schemas:"]
        
        subgraph LOOP["Process Each Schema"]
            D1["schema_key = 'RWDSchema'<br/>schema_value = 'iuhealth_ed_data_cohort_202306'"]
            D2["Find callFunc where<br/>schema_type == schema_key"]
            D3{"callFunc<br/>found?"}
            D4{"database_exists<br/>(schema_value)?"}
            D5["Get data_type from callFunc<br/>e.g., 'RWDTables'"]
            D6["Get table definitions:<br/>config_dict[data_type]"]
            D7["Create Item for each table"]
            D8["Create TableList from Items"]
            D9["setattr(self, type_key, TableList)<br/>e.g., self.rwd = TableList"]
            D10["setattr(self, property_name, DB)<br/>e.g., self.r = DB(...)"]
            
            D1 --> D2 --> D3
            D3 -->|Yes| D4
            D3 -->|No| SKIP1["Log: No matching callFunc<br/>Skip schema"]
            D4 -->|Yes| D5
            D4 -->|No| SKIP2["Log: Schema not found<br/>Skip schema"]
            D5 --> D6 --> D7 --> D8 --> D9 --> D10
        end
        
        C1 --> C2 --> C3 --> LOOP
    end

    subgraph RESULT["Final State"]
        E1["resource.rwd = TableList[Item]"]
        E2["resource.r = DB (DataFrame access)"]
        E3["resource.proj = TableList[Item]"]
        E4["resource.db = DB (DataFrame access)"]
        E5["resource.config_dict = merged config"]
    end

    A5 -->|Yes| CONFIG
    A5 -->|No| DEFER["Deferred: call finish_init() manually"]
    CONFIG --> PROCESS
    PROCESS --> RESULT

    style INIT fill:#e1f5fe
    style CONFIG fill:#fff3e0
    style PROCESS fill:#e8f5e9
    style RESULT fill:#f3e5f5
    style LOOP fill:#e8f5e9
```

